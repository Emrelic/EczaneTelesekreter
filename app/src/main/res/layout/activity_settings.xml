<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ==================== -->
        <!-- ECZANE BİLGİLERİ -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Eczane Bilgileri"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:drawablePadding="8dp"
                    android:paddingBottom="12dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Eczane Adi"
                    android:layout_marginBottom="8dp"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/setEczaneAdi"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Adres"
                    android:layout_marginBottom="8dp"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/setEczaneAdres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Telefon Numarasi"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/setEczaneTelefon"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== -->
        <!-- KONUM AYARLARI -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Konum Ayarlari"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/setKonumStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Konum: Ayarlanmamis"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <Button
                    android:id="@+id/setBtnKonumGps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GPS ile Konumumu Al"
                    android:backgroundTint="#1565C0"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="veya elle girin:"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:gravity="center"
                    android:paddingBottom="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Enlem"
                        android:layout_marginEnd="4dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusBottomEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/setLatitude"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Boylam"
                        android:layout_marginStart="4dp"
                        app:boxBackgroundMode="outline"
                        app:boxCornerRadiusTopStart="8dp"
                        app:boxCornerRadiusTopEnd="8dp"
                        app:boxCornerRadiusBottomStart="8dp"
                        app:boxCornerRadiusBottomEnd="8dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/setLongitude"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal|numberSigned"
                            android:textSize="13sp" />
                    </com.google.android.material.textfield.TextInputLayout>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== -->
        <!-- SES MESAJI AYARLARI -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ses Mesaji Ayarlari"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#D32F2F"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/setSesStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ses mesaji: Henuz kaydedilmedi"
                    android:textSize="14sp"
                    android:paddingBottom="12dp" />

                <Button
                    android:id="@+id/setBtnKendiSes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Kendi Sesimle Kaydet"
                    android:backgroundTint="#1B5E20"
                    android:textColor="#FFFFFF"
                    android:layout_marginBottom="8dp" />

                <Button
                    android:id="@+id/setBtnYapayZeka"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Yapay Zeka ile Ses Olustur"
                    android:backgroundTint="#6A1B9A"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== -->
        <!-- WHATSAPP AYARLARI -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Ayarlari"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#075E54"
                    android:paddingBottom="8dp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/setSwitchWhatsapp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Arama sonrasi WhatsApp konum gonder"
                    android:textSize="15sp"
                    android:minHeight="48dp"
                    android:paddingBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Ek WhatsApp mesaji (opsiyonel)"
                    android:layout_marginBottom="12dp"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/setWhatsappMesaj"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:hint="Ornegin: 7/24 hizmetinizdeyiz" />
                </com.google.android.material.textfield.TextInputLayout>

                <Button
                    android:id="@+id/setBtnWhatsappOnizleme"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp Mesaj Onizleme"
                    android:backgroundTint="#25D366"
                    android:textColor="#FFFFFF" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== -->
        <!-- ZAMANLAMA AYARLARI -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Zamanlama Ayarlari"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#E65100"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mesaj bittikten sonra hicbir tusa basilmazsa otomatik olarak eczaneye baglanma suresi:"
                    android:textSize="13sp"
                    android:textColor="#666666"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/setTvTimeout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Otomatik baglama suresi: 30 saniye"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="4dp" />

                <SeekBar
                    android:id="@+id/setSeekTimeout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="4" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="10 sn"
                        android:textSize="11sp"
                        android:textColor="#999999" />
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="60 sn"
                        android:textSize="11sp"
                        android:textColor="#999999"
                        android:gravity="end" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- KAYDET BUTONU -->
        <Button
            android:id="@+id/setBtnKaydet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Tum Ayarlari Kaydet"
            android:backgroundTint="#1B5E20"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
