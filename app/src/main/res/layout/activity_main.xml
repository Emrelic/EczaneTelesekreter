<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Baslik -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Nobetci Eczane\nOtomatik Telesekreter"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ==================== -->
        <!-- ANA SWITCH -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:background="#FFFFFF">

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchService"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NOBET MODU"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:minHeight="56dp" />

                <TextView
                    android:id="@+id/tvServiceStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="NOBET MODU: KAPALI"
                    android:textSize="15sp"
                    android:paddingTop="8dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== -->
        <!-- DURUM OZETI -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Durum Ozeti"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="12dp" />

                <!-- Eczane bilgisi -->
                <TextView
                    android:id="@+id/tvEczaneBilgi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Eczane bilgileri girilmemis"
                    android:textSize="14sp"
                    android:paddingBottom="8dp"
                    android:lineSpacingMultiplier="1.3" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="8dp" />

                <!-- Ses mesaji durumu -->
                <TextView
                    android:id="@+id/tvSesStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ses mesaji: -"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <!-- Konum durumu -->
                <TextView
                    android:id="@+id/tvKonumStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Konum: -"
                    android:textSize="14sp"
                    android:paddingBottom="8dp" />

                <!-- WhatsApp durumu -->
                <TextView
                    android:id="@+id/tvWhatsappStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp: -"
                    android:textSize="14sp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ==================== -->
        <!-- AYARLAR BUTONU -->
        <!-- ==================== -->
        <Button
            android:id="@+id/btnAyarlar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="AYARLAR"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- ==================== -->
        <!-- NASIL CALISIR -->
        <!-- ==================== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#E8F5E9">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nasil Calisir?"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Ayarlar'dan eczane bilgilerinizi girin\n2. Ses mesajinizi kaydedin\n3. Eczane konumunu ayarlayin\n4. Nobetci gunu NOBET MODU'nu acin\n\nArama geldiginde:\n- Telefon otomatik cevaplanir\n- Ses mesajiniz calinir\n- Arayan kisiye WhatsApp ile konum gonderilir\n- 1'e basarsa: Mesaj tekrar calar\n- 2'ye basarsa: Eczaneye baglanir\n- Hicbir tusa basmazsa: 30 sn sonra otomatik baglanir"
                    android:textSize="13sp"
                    android:textColor="#333333"
                    android:lineSpacingMultiplier="1.4" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
