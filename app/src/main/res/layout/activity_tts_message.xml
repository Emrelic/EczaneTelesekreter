<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Başlık -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yapay Zeka ile\nSes Mesajı Oluştur"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <!-- Durum -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Yükleniyor..."
            android:textSize="14sp"
            android:textColor="#1565C0"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- Şablon Oluştur -->
        <Button
            android:id="@+id/btnSablonOlustur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Eczane Bilgilerinden Şablon Oluştur"
            android:backgroundTint="#FF8F00"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- Mesaj Metni -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mesaj Metni"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aşağıdaki metni düzenleyin. Yapay zeka bu metni Türkçe olarak okuyacak."
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:paddingBottom="8dp" />

                <EditText
                    android:id="@+id/etMesajMetni"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minLines="6"
                    android:maxLines="12"
                    android:gravity="top|start"
                    android:inputType="textMultiLine|textCapSentences"
                    android:hint="Mesajınızı buraya yazın veya şablon oluşturun..."
                    android:padding="12dp"
                    android:background="#F9FBE7"
                    android:textSize="15sp"
                    android:textColor="#333333" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Ses Ayarları -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ses Ayarları"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:paddingBottom="12dp" />

                <!-- Konuşma Hızı -->
                <TextView
                    android:id="@+id/tvHiz"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Konuşma Hızı: 0.9x"
                    android:textSize="14sp"
                    android:textColor="#555555" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Yavaş"
                        android:textSize="11sp"
                        android:textColor="#999999" />

                    <SeekBar
                        android:id="@+id/seekBarHiz"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="20"
                        android:progress="8"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hızlı"
                        android:textSize="11sp"
                        android:textColor="#999999" />
                </LinearLayout>

                <!-- Ses Tonu -->
                <TextView
                    android:id="@+id/tvTon"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ses Tonu: 1.0x"
                    android:textSize="14sp"
                    android:textColor="#555555" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kalın"
                        android:textSize="11sp"
                        android:textColor="#999999" />

                    <SeekBar
                        android:id="@+id/seekBarTon"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:max="20"
                        android:progress="10"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="İnce"
                        android:textSize="11sp"
                        android:textColor="#999999" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Butonlar -->
        <Button
            android:id="@+id/btnDinle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Önce Dinle (Önizleme)"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnKaydet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Bu Mesajı Kaydet ve Kullan"
            android:backgroundTint="#1B5E20"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="24dp" />

    </LinearLayout>
</ScrollView>
